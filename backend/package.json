{
	"name": "seniorlauncher-remote-backend",
	"version": "1.0.0",
	"private": true,
	"description": "Minimal backend (TypeScript + Bun) for Senior Launcher sync",
	"module": "server.ts",
	"scripts": {
		"start": "bun run server.ts",
		"dev": "bun --watch run server.ts",
		"check": "bun run --no-install tsc --noEmit"
	},
	"engines": {
		"bun": ">=1.1.0"
	},
	"devDependencies": {
		"typescript": "^5.6.3",
		"@types/bun": "latest"
	}
}